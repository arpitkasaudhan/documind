# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get free DB: https://neon.tech
DATABASE_URL="postgresql://user:password@host/documind?sslmode=require"

# ─── NextAuth v5 ──────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth (optional — for Google sign-in) ────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Anthropic Claude (chat + extraction + reports) ──────────────────────────
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=""

# ─── OpenAI (embeddings only — text-embedding-3-small) ───────────────────────
# Get key: https://platform.openai.com
OPENAI_API_KEY=""

# ─── Pinecone (vector database for RAG) ──────────────────────────────────────
# Free tier: https://pinecone.io — create index "documind", 1536 dims, cosine
PINECONE_API_KEY=""
PINECONE_INDEX="documind"

# ─── AWS S3 (file storage) ────────────────────────────────────────────────────
# Create bucket "documind-files" with private ACL, enable CORS for your domain
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="documind-files"

# ─── Stripe (payments) ────────────────────────────────────────────────────────
# Test keys from: https://stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRO_PRICE_ID=""

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
